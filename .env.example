# NVIDIA Nemotron / NIM settings
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NEMOTRON_MODEL_NAME=

# Controlled lab target
TARGET_URL=http://<TARGET_IP>:8088
APPROVED_TARGET_HOST=<TARGET_IP>

# MVP safety mode
READ_ONLY_MODE=true
ENABLE_FIX_MODE=false
ENABLE_FIREWALL_HARDENING=false
