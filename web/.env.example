# `npm run dev` starts FastAPI + Vite (wait-on :8000). Frontend-only: `npm run dev:vite` + run API separately (or 502 on /api).
# If the API is not on :8000, set VITE_DEV_API_PROXY_TARGET and use the same port in backend.
# Dev default: leave unset — same-origin /api via Vite proxy (avoids cross-origin + PNA issues). Uncomment for direct API:
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Where Vite should proxy /api in dev & preview (if FastAPI is not on :8000).
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000

# true = offline demo only (no POST /api/review). false = live API (needs FastAPI; use VITE_API_BASE_URL and/or Vite proxy).
VITE_USE_MOCK=false
